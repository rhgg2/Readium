@module editCursor  src=editCursor.lua  loc=973  sha=4f21dd7
@deps util

# Module-level functions (private)
  @fn print(...)

@factory newEditCursor(deps)

  # Private state
    @state grid = deps.grid
    @state cm = deps.cm
    @state getRPBar = deps.rowPerBar
    @state moveHook = deps.moveHook or function () end
    @state ec = {}

  # Private functions
    @fn clampPos()
    @fn partAt(col, stop)
    @fn cursorPart()
    @fn firstStopForPart(col, part)
    @fn isSticky()
    @fn selStart()
    @fn selUpdate()
    @fn selClear()
    @fn cycleHBlock()
    @fn cycleVBlock()
    @fn swapEnds()

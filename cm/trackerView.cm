@module trackerView  src=trackerView.lua  loc=2255  sha=1a802ec
@deps util, midiManager, trackerManager, tuning, commandManager, editCursor

# Module-level functions (private)
  @fn print(...)

@factory newViewContext(args)

  # Private state
    @state swing = args.swing
    @state rowPPQs = args.rowPPQs
    @state length = args.length
    @state numRows = args.numRows
    @state rowPerBeat = args.rowPerBeat
    @state ppqPerRow = args.ppqPerRow
    @state timeSigs = args.timeSigs
    @state temper = args.temper
    @state ctx = {}


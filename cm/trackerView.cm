    @fn reswingCore(groups, opts)   -- opts: { include?, target, restamp? }. Each event carries its own .frame and .ppqL (stamped
    @fn reswingScope(groups)
    @fn quantizeScope(groups)   -- Plan-then-write so conformOverlaps can clip plan geometry against col-mates before the wri
    @fn quantizeKeepRealisedScope(groups)   -- Shift intent onset onto grid; delay absorbs the inverse so realised onset is preserved. En
    @fn shiftPlan(col, e, dLogical, swing, f)   -- Build a shift plan for one event by `dLogical` rows under `swing` and `f`. ppq is re-reali
    @fn insertRowCore(col, topRow, numRows)
    @fn deleteRowCore(col, topRow, numRows)
    @fn forEachRowOp(core, preSel)

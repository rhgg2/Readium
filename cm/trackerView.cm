    @fn queueDeleteNotes(col, locs)   -- Delete notes; extend each predecessor that ended at-or-past a deleted run into the next su
    @fn queueResetDelays(col, locs)
    @fn queueResetVelocities(col, locs)   -- Reset selected note vels to the prior event's vel (notes or PAs carry forward); delete sel
    @fn queueDeleteCCs(col, locs)
